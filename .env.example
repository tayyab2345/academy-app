# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/academyflow?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here" # openssl rand -base64 32

# Document storage
# STORAGE_PROVIDER="vercel_blob" # optional on Vercel if BLOB_READ_WRITE_TOKEN is present
STORAGE_PROVIDER="local" # use "vercel_blob" on Vercel or "netlify_blobs" on Netlify
DOCUMENT_STORAGE_URL="/api/documents"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
# NETLIFY_BLOBS_DOCUMENT_STORE="academy-documents"

# Optional: Academy lifecycle
# ACADEMY_RECOVERY_WINDOW_DAYS="14"

# Optional: Email
# EMAIL_PROVIDER="resend"
# EMAIL_FROM="noreply@yourdomain.com"
# RESEND_API_KEY="re_xxx"

# Optional: Internal jobs/reminders
# INTERNAL_API_TOKEN="change-me"

# Optional: Local PDF browser override
# PUPPETEER_EXECUTABLE_PATH=""
