# Database
# Local development:
DATABASE_URL="postgresql://postgres:password@localhost:5432/academyflow?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/academyflow?schema=public"

# Supabase on Vercel or another serverless platform:
# DATABASE_URL="postgresql://prisma.PROJECT_REF:YOUR_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Railway:
# DATABASE_URL="${{Postgres.DATABASE_URL}}"
# DIRECT_URL="${{Postgres.DATABASE_URL}}"

# NextAuth
NEXTAUTH_URL="http://localhost:3000" # production: https://your-app.vercel.app
NEXTAUTH_SECRET="your-secret-key-here" # openssl rand -base64 32

# Temporary degraded-mode fallbacks
# DEMO_MODE="true"
# SKIP_SUBDOMAIN_CHECK="true"
# TEMP: disable academy registration OTP/email verification for local/dev/demo.
# Set this to "true" when you want to re-enable OTP verification later.
EMAIL_VERIFICATION_REQUIRED="false"

# Document storage
# STORAGE_PROVIDER="vercel_blob" # optional on Vercel if BLOB_READ_WRITE_TOKEN is present
STORAGE_PROVIDER="local" # use "vercel_blob" on Vercel, "netlify_blobs" on Netlify, or "database" for persistent Railway-safe uploads
DOCUMENT_STORAGE_URL="/api/documents"
# Railway:
# - if you mount a persistent volume, keep STORAGE_PROVIDER="local" and set DOCUMENT_STORAGE_PATH
# - without a mounted volume, the app now auto-falls back to persistent database storage
# DOCUMENT_STORAGE_PATH="/app/storage/documents"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
# NETLIFY_BLOBS_DOCUMENT_STORE="academy-documents"

# Optional: Academy lifecycle
# ACADEMY_RECOVERY_WINDOW_DAYS="14"

# Email
# Required for academy registration email verification.
# EMAIL_PROVIDER="resend"
# EMAIL_FROM="noreply@yourdomain.com"
# RESEND_API_KEY="re_xxx"

# Optional: Internal jobs/reminders
# INTERNAL_API_TOKEN="change-me"

# Optional: Local PDF browser override
# PUPPETEER_EXECUTABLE_PATH=""
